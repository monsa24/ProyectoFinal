@model TiendaOnline.Models.Orden
@{ ViewData["Title"] = "¡Compra Confirmada!"; }

<div class="container">
    <div style="max-width:600px;margin:4rem auto;background:#fff;border-radius:16px;
                box-shadow:0 4px 24px rgba(0,0,0,.1);padding:2.5rem;text-align:center;">
        <div style="font-size:4rem;">✅</div>
        <h2 style="font-weight:800;color:#2c3e50;">¡Compra exitosa!</h2>
        <p class="text-muted">Tu pedido fue recibido y está siendo procesado.</p>
        <div style="background:#f0faf5;border-radius:8px;padding:.8rem;font-weight:700;
                    color:#27ae60;font-size:1.1rem;margin:1rem 0;">
            🧾 Orden #@Model.Id
        </div>

        <table class="table table-bordered mt-3 text-left">
            <thead style="background:#2c3e50;color:#fff;">
                <tr><th>Producto</th><th>Cant.</th><th>Subtotal</th></tr>
            </thead>
            <tbody>
                @foreach (var d in Model.Detalles)
                {
                    <tr>
                        <td>@d.Nombre</td>
                        <td>@d.Cantidad</td>
                        <td style="font-weight:600;">₡@d.Subtotal.ToString("N2")</td>
                    </tr>
                }
                <tr style="font-weight:800;color:#27ae60;">
                    <td colspan="2">Total pagado</td>
                    <td>₡@Model.Total.ToString("N2")</td>
                </tr>
            </tbody>
        </table>

        <div style="background:#f8f9fa;border-radius:8px;padding:1rem;text-align:left;font-size:.9rem;color:#555;margin-top:1rem;">
            <strong>📦 Dirección:</strong> @Model.Direccion<br />
            <strong>💳 Pago:</strong> @Model.MetodoPago<br />
            <strong>📅 Fecha:</strong> @Model.Fecha.ToString("dd/MM/yyyy HH:mm")
        </div>

        <a href="@Url.Action("Index")" class="btn btn-primary mt-4" style="font-weight:700;padding:.8rem 2rem;">
            🛍️ Seguir comprando
        </a>
    </div>
</div>