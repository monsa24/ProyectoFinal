@model IEnumerable<TiendaOnline.Models.ProductoModels>

@{
    ViewBag.Title = "Catálogo de Productos";
}

<h2 class="mb-4">Catálogo de Productos</h2>

@if (User.IsInRole("Admin"))
{
    <p>
        @Html.ActionLink("➕ Agregar Producto", "Crear", "Productos", null, new { @class = "btn btn-success" })
    </p>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<style>
    .card-producto {
        border: 1px solid #ddd;
        border-radius: 10px;
        padding: 15px;
        height: 100%;
        transition: 0.3s;
    }

        .card-producto:hover {
            transform: scale(1.03);
            box-shadow: 0px 4px 10px rgba(0,0,0,0.2);
        }

    .img-producto {
        width: 100%;
        height: 200px;
        object-fit: cover;
        border-radius: 10px;
    }
</style>

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-md-4" style="margin-bottom:20px;">
            <div class="card-producto">

                <!-- 🖼️ IMAGEN -->
                <div style="text-align:center;">
                    @if (item.Imagen != null)
                    {
                        var base64 = Convert.ToBase64String(item.Imagen);
                        var imgSrc = String.Format("data:image/png;base64,{0}", base64);

                        <img src="@imgSrc" class="img-producto" />
                    }
                </div>

                <!-- 📦 INFO -->
                <h4 style="margin-top:10px;">@item.Nombre</h4>
                <p><strong>Código:</strong> @item.Codigo</p>
                <p><strong>Precio:</strong> @item.Precio.ToString("C", new System.Globalization.CultureInfo("es-CR"))</p>
                <p><strong>Stock:</strong> @item.Disponibilidad</p>

                <!-- 🔘 BOTONES -->
                <div style="margin-top:10px;">

                    @Html.ActionLink("Ver", "Details", new { id = item.Id }, new { @class = "btn btn-info btn-sm" })

                    <!-- 🔐 ADMIN -->
                    @if (User.IsInRole("Admin"))
                    {
                        @Html.ActionLink("Editar", "Edit", new { id = item.Id }, new { @class = "btn btn-warning btn-sm" })
                        @Html.ActionLink("Eliminar", "Delete", new { id = item.Id }, new { @class = "btn btn-danger btn-sm" })
                    }

                    <!-- 👤 USUARIO -->
                    @if (User.IsInRole("Usuario"))
                    {
                        if (item.Disponibilidad > 0)
                        {
                            @Html.ActionLink("Agregar al carrito", "Agregar", "Carrito", new { id = item.Id }, new { @class = "btn btn-primary btn-sm" })
                        }
                        else
                        {
                            <span class="text-danger">Sin stock</span>
                        }
                    }

                </div>

            </div>
        </div>
    }

</div>