@model IEnumerable<TiendaOnline.Models.ItemCarrito>
@{
    ViewData["Title"] = "Mi Carrito";
    var items = Model.ToList();
}

<div style="background:linear-gradient(135deg,#2c3e50,#3498db);color:#fff;padding:2rem;border-radius:0 0 12px 12px;margin-bottom:2rem;">
    <h2>🛒 Mi Carrito</h2>
</div>

<div class="container">
    @if (!items.Any())
    {
        <div class="text-center py-5">
            <p style="font-size:3rem;">🛒</p>
            <h4>Tu carrito está vacío</h4>
            <a href="@Url.Action("Index")" class="btn btn-primary mt-3">Ver productos</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <table class="table table-bordered bg-white shadow-sm" style="border-radius:12px;overflow:hidden;">
                    <thead style="background:#2c3e50;color:#fff;">
                        <tr>
                            <th>Producto</th>
                            <th>Precio</th>
                            <th>Cantidad</th>
                            <th>Subtotal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in items)
                        {
                            <tr id="fila-@item.ProductoId">
                                <td>
                                    <strong>@item.Nombre</strong><br />
                                    <small class="text-muted">Cód: @item.Codigo</small>
                                </td>
                                <td>₡@item.Precio.ToString("N2")</td>
                                <td style="width:140px;">
                                    <div class="input-group input-group-sm">
                                        <button class="btn btn-outline-secondary"
                                                onclick="actualizar(@item.ProductoId, -1)" type="button">
                                            −
                                        </button>
                                        <input type="number" id="qty-@item.ProductoId"
                                               value="@item.Cantidad" min="0"
                                               class="form-control text-center"
                                               onchange="actualizarDirecto(@item.ProductoId)" />
                                        <button class="btn btn-outline-secondary"
                                                onclick="actualizar(@item.ProductoId, 1)" type="button">
                                            +
                                        </button>
                                    </div>
                                </td>
                                <td id="subtotal-@item.ProductoId" style="font-weight:700;color:#27ae60;">
                                    ₡@item.Subtotal.ToString("N2")
                                </td>
                                <td>
                                    <button class="btn btn-sm btn-outline-danger"
                                            onclick="eliminar(@item.ProductoId)">
                                        🗑️
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @using (Html.BeginForm("VaciarCarrito", "Productos", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-sm"
                            onclick="return confirm('¿Vaciar el carrito?')">
                        🗑️ Vaciar carrito
                    </button>
                }
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm p-4" style="border-radius:12px;">
                    <h5 style="font-weight:700;color:#2c3e50;">📋 Resumen</h5>
                    <hr />
                    <div class="d-flex justify-content-between mb-2">
                        <span>Envío</span>
                        <span style="color:#27ae60;font-weight:600;">Gratis</span>
                    </div>
                    <div class="d-flex justify-content-between" style="font-size:1.2rem;font-weight:800;color:#2c3e50;">
                        <span>Total</span>
                        <span id="totalCarrito">₡@ViewBag.Total.ToString("N2")</span>
                    </div>
                    <a href="@Url.Action("Checkout")"
                       class="btn btn-success btn-block mt-4" style="font-weight:700;">
                        Proceder al pago →
                    </a>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-block mt-2">
                        ← Seguir comprando
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        var token = $('input[name="__RequestVerificationToken"]').val();

        function actualizar(productoId, delta) {
            var input = document.getElementById('qty-' + productoId);
            var nuevaCantidad = Math.max(0, parseInt(input.value) + delta);
            input.value = nuevaCantidad;
            llamarActualizar(productoId, nuevaCantidad);
        }

        function actualizarDirecto(productoId) {
            var val = parseInt(document.getElementById('qty-' + productoId).value) || 0;
            llamarActualizar(productoId, val);
        }

        function llamarActualizar(productoId, cantidad) {
            $.ajax({
                url: '@Url.Action("ActualizarCantidad", "Productos")',
                type: 'POST',
                data: { productoId: productoId, cantidad: cantidad, __RequestVerificationToken: token },
                success: function (data) {
                    if (data.success) {
                        if (cantidad === 0) {
                            $('#fila-' + productoId).fadeOut(300, function () { $(this).remove(); });
                        } else {
                            $('#subtotal-' + productoId).text('₡' + formatNum(data.subtotal));
                        }
                        $('#totalCarrito').text('₡' + formatNum(data.total));
                        if (data.totalItems === 0) setTimeout(function(){ location.reload(); }, 400);
                    }
                }
            });
        }

        function eliminar(productoId) {
            $.ajax({
                url: '@Url.Action("EliminarDelCarrito", "Productos")',
                type: 'POST',
                data: { productoId: productoId, __RequestVerificationToken: token },
                success: function (data) {
                    if (data.success) {
                        $('#fila-' + productoId).fadeOut(300, function () { $(this).remove(); });
                        $('#totalCarrito').text('₡' + formatNum(data.total));
                        if (data.totalItems === 0) setTimeout(function(){ location.reload(); }, 400);
                    }
                }
            });
        }

        function formatNum(n) {
            return parseFloat(n).toLocaleString('es-CR', { minimumFractionDigits: 2 });
        }
    </script>
}