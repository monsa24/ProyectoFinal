        </div>

        <!-- Producto 6 -->
        <div class="producto-card">
            <img class="producto-img" src="https://staging.arteacr.com/wp-content/uploads/2020/05/21090-Borrador-526-50.jpg" />
            <h4>Borrador</h4>
            <p>Borrado suave</p>
            <p class="precio">₡500</p>
            <a href="#" class="btn-comprar">Agregar</a>
        </div>

    </div>

</main>